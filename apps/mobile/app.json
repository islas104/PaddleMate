{
  "expo": {
    "name": "PaddleMate",
    "slug": "paddlemate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paddlemate.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PaddleMate does not use your camera.",
        "NSLocationWhenInUseUsageDescription": "PaddleMate uses your location to show nearby courts.",
        "NSPhotoLibraryUsageDescription": "PaddleMate does not access your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.paddlemate.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "paddlemate",
    "experiments": {
      "typedRoutes": true
    }
  }
}
